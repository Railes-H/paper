# 持久化 Postgres 数据库连接串。
# 推荐在 Vercel Marketplace 绑定 Prisma Postgres、Neon 或 Supabase Postgres 后，
# 将平台提供的连接串配置为 DATABASE_URL。
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Vercel Blob Store ID。新版本 Vercel Blob 默认使用 OIDC 认证。
# 代码使用 SDK 默认认证方式，不手动传 token。
# 本地开发请运行：
# vercel link
# vercel env pull .env.local
BLOB_STORE_ID=""
BLOB_WEBHOOK_PUBLIC_KEY=""
