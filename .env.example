# 本地 SQLite 数据库。Vercel 演示环境未配置时会回退到 /tmp/papertrack.db，
# 但生产长期数据建议改用 Postgres/Neon/Supabase 等托管数据库。
DATABASE_URL="file:/Users/railes/.papertrack/dev.db"

# Vercel Blob Store ID。新版本 Vercel Blob 默认使用 OIDC 认证。
# 代码使用 SDK 默认认证方式，不手动传 token。
# 本地开发请运行：
# vercel link
# vercel env pull .env.local
BLOB_STORE_ID=""
BLOB_WEBHOOK_PUBLIC_KEY=""
